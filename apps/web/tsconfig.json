{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "*": ["*", "./lib/*", "./pages/*"]
    },
    "types": ["node", "react", "react-dom", "vite/client"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "**/$RECYCLE.BIN",
    "../$RECYCLE.BIN",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.gif"
  ]
}
